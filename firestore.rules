rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/state/{stateDoc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /households/{householdId} {
      allow read, write: if request.auth != null && householdId.size() >= 3;

      match /routineCompletions/{completionId} {
        allow read: if request.auth != null && householdId.size() >= 3;
        allow create, update: if request.auth != null
          && householdId.size() >= 3
          && completionId == request.resource.data.taskId + '_' + request.resource.data.cycleKey
          && request.resource.data.keys().hasAll([
            'taskId', 'cycleKey', 'completedDate', 'completedAt', 'note', 'updatedAt'
          ])
          && request.resource.data.keys().hasOnly([
            'taskId', 'cycleKey', 'completedDate', 'completedAt', 'note', 'updatedAt',
            'deleted', 'deletedAt', 'source', 'weightKg'
          ])
          && request.resource.data.taskId is string
          && request.resource.data.cycleKey is string
          && request.resource.data.completedDate.matches('^\\d{4}-\\d{2}-\\d{2}$')
          && request.resource.data.completedAt is string
          && request.resource.data.updatedAt is string
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 2000
          && (!('deleted' in request.resource.data) || request.resource.data.deleted is bool)
          && (!('deletedAt' in request.resource.data) || request.resource.data.deletedAt is string)
          && (!('source' in request.resource.data) || request.resource.data.source is string)
          && (!('weightKg' in request.resource.data) || request.resource.data.weightKg is number);
        allow delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
